# 复制为 usage-stats.env 后填写（勿提交到 Git）
# 与 update-mirror.env 可共用同一台宝塔服务器 SSH 信息

STATS_BASE_URL=https://updates.bcxtech.cn/stats
STATS_REMOTE_DIR=/www/wwwroot/updates.bcxtech.cn/stats

SSH_HOST=
SSH_USER=root
SSH_PORT=22
# SSH_KEY_PATH=./xiaobao.pem

# MySQL（宝塔 → 数据库 中创建的 XBoom 库账号，或 root）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=XBoom
MYSQL_USER=root
MYSQL_PASSWORD=
