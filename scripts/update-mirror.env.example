# 复制为 update-mirror.env 后填写（勿提交到 Git）
# 腾讯云宝塔：安装包 + version-policy.json 通过 SSH 上传到站点目录

MIRROR_BASE_URL=https://updates.bcxtech.cn/updates

SSH_HOST=
SSH_USER=root
SSH_PORT=22
REMOTE_DIR=/www/wwwroot/updates.bcxtech.cn/updates

# SSH：项目根目录 xiaobao.pem（推荐），或 SSH_KEY_PATH=./xiaobao.pem
# 也可用密码（勿写入文件）: $env:SSH_PASSWORD='...'
 